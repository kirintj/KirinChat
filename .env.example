# 本地开发环境配置示例
# 请复制此文件为 .env 并填入真实值
# cp .env.example .env

# ===========================================================
# 数据库配置
# ===========================================================

# MySQL 主连接 (用于生产环境)
MYSQL_ENDPOINT=mysql+pymysql://root:your_password@localhost:3306/kirinchat

# MySQL 异步连接 (用于异步数据库操作)
MYSQL_ASYNC_ENDPOINT=mysql+aiomysql://root:your_password@localhost:3306/kirinchat

# ===========================================================
# Redis 配置
# ===========================================================

REDIS_ENDPOINT=redis://localhost:6379

# ===========================================================
# AI 模型 API Keys
# ===========================================================

# 通义千问 API Key
CONVERSATION_MODEL_API_KEY=your_api_key
TOOL_CALL_MODEL_API_KEY=your_api_key
REASONING_MODEL_API_KEY=your_api_key

# 文生图 / 多模态 / Embedding / Rerank 模型 API Key
TEXT2IMAGE_API_KEY=your_api_key
QWEN_VL_API_KEY=your_api_key
EMBEDDING_API_KEY=your_api_key
RERANK_API_KEY=your_api_key

# ===========================================================
# 工具 API Keys
# ===========================================================

# 高德天气 API Key
AMAP_WEATHER_API_KEY=your_api_key

# Tavily API Key
TAVILY_API_KEY=your_api_key

# Google Search API Key
GOOGLE_SEARCH_API_KEY=your_api_key

# 快递查询 API Key
DELIVERY_API_KEY=your_api_key

# BoCha API Key
BOCHA_API_KEY=your_api_key

# ===========================================================
# 存储配置
# ===========================================================

# MinIO 配置 (本地开发)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_BUCKET=agentchat

# MySQL Docker 密码 (用于 docker-compose)
MYSQL_ROOT_PASSWORD=123456
MYSQL_PASSWORD=123456

# OSS 配置 (生产环境 - 可选)
OSS_ACCESS_KEY_ID=your_oss_access_key
OSS_ACCESS_KEY_SECRET=your_oss_secret_key

# ===========================================================
# 微信配置 (可选)
# ===========================================================

WECHAT_TOKEN=your_wechat_token
WECHAT_APP_ID=your_wechat_app_id
WECHAT_SECRET=your_wechat_secret

# ===========================================================
# Langfuse 配置 (可选)
# ===========================================================

LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key

# ===========================================================
# 其他配置
# ===========================================================

# 开发环境标识
APP_ENV=dev

# 端口号
APP_PORT=7860
